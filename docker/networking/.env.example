# Copy to .env and fill in real values before running `docker compose up -d`.
# .env is gitignored.

DOMAIN_SUFFIX=home.arpa

# Cloudflare Tunnel token issued in the Zero Trust dashboard. The Ansible
# bootstrap playbook also writes this file at /home/steven/app/networking/.env
# on the host, so this template is mainly here for manual operation.
TUNNEL_TOKEN=REPLACE_WITH_CLOUDFLARE_TUNNEL_TOKEN
