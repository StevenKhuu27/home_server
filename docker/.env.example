# Copy to .env and fill in real values before running `docker compose up -d`.
# .env is gitignored.

# Suffix used by every service's Traefik Host() rule, e.g. `home.arpa` makes
# Grafana reachable at https://grafana.home.arpa via AdGuard DNS rewrites.
DOMAIN_SUFFIX=home.arpa

# Public hostname for n8n (must match a Cloudflare Tunnel public hostname).
N8N_HOST=n8n.example.com

# Timezone string for containers that respect TZ.
TZ=Australia/Sydney

# Grafana admin login. Set a strong password before first boot - Grafana
# bakes the initial password into its DB.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_ME

# Basic-auth credentials for the Traefik dashboard, in htpasswd bcrypt form.
# Generate with: htpasswd -nbB admin 'your-password'
# Note: dollar signs must be doubled in .env to escape compose interpolation.
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$REPLACE_WITH_REAL_BCRYPT_HASH
