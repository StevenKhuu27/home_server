# --- Terraform ---

**/.terraform/

# State files (may contain secrets - never commit)
*.tfstate
*.tfstate.*

# Variable files - but keep example templates
*.tfvars
*.tfvars.json
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Local CLI config and override files
.terraformrc
terraform.rc
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# NOTE: .terraform.lock.hcl committed on purpose to gurantee version consistency.

# --- Ansible ---

# Real inventory (may leak internal IPs) - example template is committed
ansible/inventory/inventory
!ansible/inventory/inventory.example

# Retry files and local collection cache
*.retry
ansible/collections/

# Vault password files - never commit these
.vault_pass
.vault_pass.txt
vault_password_file

# --- Secrets ---
.env
.env.*
!.env.example

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
